{
    "name": "ensi/laravel-elastic-query",
    "description": "laravel elastic query",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "elasticsearch/elasticsearch": "^7.13",
        "laravel/framework": "^9.0 || ^10.0 || ^11.0",
        "webmozart/assert": "^1.11"
    },
    "require-dev": {
        "ensi/laravel-test-factories": "^1.0.0",
        "friendsofphp/php-cs-fixer": "^3.2",
        "pestphp/pest": "^1.22 || ^2.0",
        "pestphp/pest-plugin-laravel": "^1.1 || ^2.0",
        "phpstan/extension-installer": "^1.3",
        "phpstan/phpstan": "^1.11",
        "spaze/phpstan-disallowed-calls": "^2.15",
        "orchestra/testbench": "^7.0 || ^8.0 || ^9.0"
    },
    "autoload": {
        "psr-4": {
            "Ensi\\LaravelElasticQuery\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ensi\\LaravelElasticQuery\\Tests\\": "tests"
        }
    },
    "scripts": {
        "cs": "php-cs-fixer fix --config .php-cs-fixer.php",
        "phpstan": "phpstan analyse",
        "test": "./vendor/bin/pest --parallel --no-coverage",
        "test-ci": "./vendor/bin/pest --no-coverage --group=unit",
        "test-coverage": "XDEBUG_MODE=coverage ./vendor/bin/pest --parallel --coverage"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ensi\\LaravelElasticQuery\\ElasticQueryServiceProvider"
            ],
            "aliases": {
                "ElasticQuery": "Ensi\\LaravelElasticQuery\\ElasticQuery"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true,
            "php-http/discovery": true
        }
    }
}
